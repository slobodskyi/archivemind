# Copy to .env.local (gitignored). Local values: `supabase status` from the
# repo root (our local stack runs on the 546xx port block). Production values:
# Supabase project settings → API (see issue #4 for the full provisioning list).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54621
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Drive import (ADR 0025). Client-side trio comes from the Google Cloud
# console (Picker API key is referrer-restricted; project NUMBER feeds setAppId).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_PICKER_API_KEY=
NEXT_PUBLIC_GOOGLE_PROJECT_NUMBER=
# Server-only: the import OAuth client (NOT the login client) + token crypto.
# TOKEN_ENC_KEY = `openssl rand -base64 32`, identical on Vercel and Railway.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TOKEN_ENC_KEY=
# Service-role key — used ONLY by lib/integrations/* (ESLint-fenced, ADR 0025).
SUPABASE_SERVICE_ROLE_KEY=

{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git worktree list)",
      "Bash(pnpm run dev)",
      "Bash(pnpm run lint)",
      "Bash(pnpm run build)",
      "Bash(pnpm run typecheck)",
      "Bash(pnpm turbo run *)",
      "Bash(pnpm exec tsc --noEmit)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(git rebase*)",
      "Bash(git reset --hard*)",
      "Bash(git worktree remove*)",
      "Bash(vercel*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)"
    ]
  }
}
